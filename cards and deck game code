import random

# Constants for creating the deck
suits = ('Hearts', 'Diamonds', 'Spades', 'Clubs')
ranks = ('Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten', 'Jack', 'Queen', 'King', 'Ace')
values = {'Two': 2, 'Three': 3, 'Four': 4, 'Five': 5, 'Six': 6, 'Seven': 7, 'Eight': 8, 'Nine': 9, 'Ten': 10,
          'Jack': 10, 'Queen': 10, 'King': 10, 'Ace': 11}

# Global variable to control the game loop state
playing = True


# --- CLASSES ---

class Card:
    """Represents a single playing card."""
    def __init__(self, suit, rank):
        self.suit = suit
        self.rank = rank

    def __str__(self):
        return f"{self.rank} of {self.suit}"


class Deck:
    """Represents a deck of 52 playing cards."""
    def __init__(self):
        self.deck = []
        for suit in suits:
            for rank in ranks:
                self.deck.append(Card(suit, rank))

    def shuffle(self):
        """Shuffles the deck randomly."""
        random.shuffle(self.deck)

    def deal(self):
        """Pops a single card off the deck."""
        return self.deck.pop()


class Hand:
    """Represents the cards held by either the Player or the Dealer."""
    def __init__(self):
        self.cards = []
        self.value = 0
        self.aces = 0  # Track Aces to adjust value dynamically (11 or 1)

    def add(self, card):
        """Adds a card to the hand."""
        self.cards.append(card)
        self.value += values[card.rank]
        if card.rank == 'Ace':
            self.aces += 1

    def adjust_for_ace(self):
        """If total value > 21 and there are Aces, convert an Ace value from 11 to 1."""
        while self.value > 21 and self.aces:
            self.value -= 10
            self.aces -= 1


class Chips:
    """Tracks the player's total chips and bets."""
    def __init__(self):
        self.total = 100  # Default starting chips
        self.bet = 0

    def win_bet(self):
        self.total += self.bet

    def lose_bet(self):
        self.total -= self.bet



def take_bet(chips):
    """Prompts the player to enter a valid bet amount."""
    while True:
        try:
            chips.bet = int(input(f"Your total chips: {chips.total}. Enter your bet: "))
        except ValueError:
            print("Please enter a valid integer!")
        else:
            if chips.bet > chips.total:
                print(f"Sorry, you do not have enough chips! Maximum available: {chips.total}")
            elif chips.bet <= 0:
                print("Your bet must be greater than 0!")
            else:
                break


def hit(deck, hand):
    """Draws a card from the deck and adjusts for any Aces."""
    hand.add(deck.deal())
    hand.adjust_for_ace()


def hit_or_stand(deck, hand):
    """Asks the player if they want to hit or stand."""
    global playing
    while True:
        choice = input("Would you like to Hit or Stand? Enter 'h' or 's': ")
        if choice.lower() == 'h':
            hit(deck, hand)
        elif choice.lower() == 's':
            print("Player stands. Dealer's turn.")
            playing = False
        else:
            print("Invalid input. Please enter 'h' or 's'.")
            continue
        break


def show_some(player, dealer):
    """Displays player's cards and only one of the dealer's cards."""
    print("\n--- DEALER'S HAND ---")
    print("<hidden card>")
    if len(dealer.cards) > 1:
        print(dealer.cards[1])  # Show the second card
    print("\n--- PLAYER'S HAND ---")
    for card in player.cards:
        print(card)
    print(f"Player's Total Value: {player.value}")


def show_all(player, dealer):
    """Displays all cards and total point values for both sides."""
    print("\n--- DEALER'S HAND ---")
    for card in dealer.cards:
        print(card)
    print(f"Dealer's Total Value: {dealer.value}")
    print("\n--- PLAYER'S HAND ---")
    for card in player.cards:
        print(card)
    print(f"Player's Total Value: {player.value}")




def player_busts(player, dealer, chips):
    print("\nPLAYER BUSTS! Dealer wins.")
    chips.lose_bet()


def player_wins(player, dealer, chips):
    print("\nPLAYER WINS!")
    chips.win_bet()


def dealer_busts(player, dealer, chips):
    print("\nDEALER BUSTS! Player wins.")
    chips.win_bet()


def dealer_wins(player, dealer, chips):
    print("\nDEALER WINS!")
    chips.lose_bet()


def push(player, dealer):
    print("\nIt's a tie! PUSH.")



player_chips = Chips()

while True:
    print("\n" + "="*30)
    print("      WELCOME TO BLACKJACK")
    print("="*30)


    game_deck = Deck()
    game_deck.shuffle()

    player_hand = Hand()
    player_hand.add(game_deck.deal())
    player_hand.add(game_deck.deal())

    dealer_hand = Hand()
    dealer_hand.add(game_deck.deal())
    dealer_hand.add(game_deck.deal())

    take_bet(player_chips)
    show_some(player_hand, dealer_hand)

    playing = True


    while playing:
        hit_or_stand(game_deck, player_hand)
        show_some(player_hand, dealer_hand)

        if player_hand.value > 21:
            player_busts(player_hand, dealer_hand, player_chips)
            break


    if player_hand.value <= 21:

        while dealer_hand.value < 17:
            hit(game_deck, dealer_hand)

        show_all(player_hand, dealer_hand)

        # Evaluate outcomes
        if dealer_hand.value > 21:
            dealer_busts(player_hand, dealer_hand, player_chips)
        elif dealer_hand.value > player_hand.value:
            dealer_wins(player_hand, dealer_hand, player_chips)
        elif dealer_hand.value < player_hand.value:
            player_wins(player_hand, dealer_hand, player_chips)
        else:
            push(player_hand, dealer_hand)


    print(f"\nPlayer total chips are at: {player_chips.total}")


    if player_chips.total <= 0:
        print("You are out of chips! Game over.")
        break


    new_game = input("Would you like to play another hand? y/n: ")
    if new_game and new_game.strip().lower() == "y":
        continue
    else:
        print("Thank you for playing!")
        break
